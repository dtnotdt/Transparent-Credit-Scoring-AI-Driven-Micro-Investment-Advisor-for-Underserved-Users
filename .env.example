# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="TetraTHON Credit Advisor"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev): leave as-is
# PostgreSQL (prod): postgresql://user:password@host:5432/dbname
DATABASE_URL=your_database_url_here

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=your_frontend_url_here

# ─── ML ───────────────────────────────────────────────────────────────────────
MODEL_PATH=./ml/models/credit_model.joblib
SHAP_EXPLAINER_PATH=./ml/models/shap_explainer.joblib

# ─── Docker / PostgreSQL (prod compose) ───────────────────────────────────────
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=your_postgres_db_here
POSTGRES_HOST=your_postgres_host_here
POSTGRES_PORT=your_postgres_port_here

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=your_google_redirect_uri_here

# ─── LLM / Conversational AI ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Admin Provisioning ───────────────────────────────────────────────────────
ADMIN_SEED_SECRET=your_admin_seed_secret_here

